<Window x:Class="KafedraApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кафедра - Данные преподавателей" Height="500" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="Преподаватели">
                <DataGrid x:Name="TeachersDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
                        <DataGridTextColumn Header="Оклад" Binding="{Binding Salary}" Width="*"/>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding AddressLine}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Нагрузка">
                <DataGrid x:Name="LoadDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding Fio}" Width="2*"/>
                        <DataGridTextColumn Header="Предмет" Binding="{Binding SubjectName}" Width="3*"/>
                        <DataGridTextColumn Header="Цикл" Binding="{Binding CycleCode}" Width="*"/>
                        <DataGridTextColumn Header="Часы" Binding="{Binding Hours}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
